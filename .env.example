# Configuración de APIs

# 🚨 IMPORTANTE PARA DATOS REALES DE CALIDAD DEL AIRE 🚨
# Obtén tu token GRATIS en: https://aqicn.org/data-platform/token/
# Este token permite obtener datos de la estación STPS de Xalapa (INECC)
WAQI_API_TOKEN=tu_token_de_aqicn_aqui

CAMS_API_KEY=tu_cams_api_key_aqui
COPERNICUS_CLIENT_ID=tu_copernicus_client_id
COPERNICUS_CLIENT_SECRET=tu_copernicus_secret
GEE_SERVICE_ACCOUNT=ruta_a_tu_archivo_credenciales.json
HERE_API_KEY=tu_here_api_key
OPENAQ_API_KEY=tu_openaq_api_key
GOOGLE_MAPS_API_KEY=tu_google_maps_api_key
TOMTOM_API_KEY=tu_tomtom_api_key

# Base de datos
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/air_quality_db

# Configuración del servidor
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Configuración de caché (opcional)
REDIS_URL=redis://localhost:6379/0

# Configuración de email para alertas (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_contraseña_de_aplicacion
ALERT_FROM_EMAIL=alertas@tudominio.com
ALERT_TO_EMAILS=destinatario1@email.com,destinatario2@email.com

# Configuración de seguridad
SECRET_KEY=genera_una_clave_secreta_segura_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Configuración de Machine Learning
ML_MODEL_PATH=./models
ML_RETRAIN_INTERVAL_DAYS=7
ML_MIN_TRAINING_SAMPLES=1000

# Límites de API
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Modo de desarrollo
DEBUG=True
ENVIRONMENT=development
