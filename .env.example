# =============================================================================
# CONFIGURACION DEL SISTEMA DE MONITOREO DE CALIDAD DEL AIRE - XALAPA
# =============================================================================
# Copia este archivo como .env y ajusta los valores segun tu entorno.
# Solo se incluyen las variables que el codigo realmente lee (os.getenv).

# =============================================================================
# BASE DE DATOS PostgreSQL (Supabase en produccion)
# =============================================================================
# En produccion el formato es el connection pooler de Supabase. Ejemplo:
#   postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres
# En desarrollo local puedes usar un Postgres local.
DATABASE_URL=postgresql://usuario:contrasena@localhost:5432/air_quality_xalapa

# =============================================================================
# ENTORNO
# =============================================================================
# Valores: development, production
ENVIRONMENT=development

# Zona horaria de visualizacion del backend. El sistema fuerza America/Mexico_City
# para mantener coherencia con los timestamps de Open-Meteo.
DISPLAY_TIMEZONE=America/Mexico_City

# URL publica del dashboard. Se usa en los correos de alerta (boton "Ver dashboard"
# y enlace de desuscripcion). En desarrollo apunta al frontend local.
DASHBOARD_URL=https://calidad-aire-xalapa.vercel.app

# =============================================================================
# CORS
# =============================================================================
# En desarrollo: permite todos los origenes.
# En produccion: lista separada por comas de dominios permitidos.
# Ejemplo: CORS_ORIGINS=https://calidad-aire-xalapa.vercel.app
CORS_ORIGINS=*

# =============================================================================
# APIs EXTERNAS
# =============================================================================
# TomTom Traffic API - https://developer.tomtom.com/
# Plan gratuito: 2,500 solicitudes / dia.
TOMTOM_API_KEY=tu_tomtom_api_key_aqui

# Open-Meteo Air Quality y wttr.in NO requieren API key.

# =============================================================================
# EMAIL PARA ALERTAS (SMTP - Gmail)
# =============================================================================
# El sistema envia correos via smtplib usando SMTP autenticado.
# Para Gmail:
#   1. Activa verificacion en dos pasos en tu cuenta de Google.
#   2. Genera una "Contrasena de aplicacion" (Settings > Security > 2-Step
#      Verification > App passwords) y usala como EMAIL_HOST_PASSWORD.
#   3. NUNCA uses tu contrasena normal de Gmail aqui.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_contrasena_de_aplicacion_de_16_caracteres
EMAIL_FROM=Sistema de Calidad del Aire <tu_correo@gmail.com>

# =============================================================================
# EXPORTACION DE DATOS PARA TESIS (opcional)
# =============================================================================
# Token de autenticacion para el endpoint /api/thesis-export. Si no se define,
# el endpoint queda inaccesible. Genera una cadena aleatoria larga.
THESIS_EXPORT_TOKEN=cadena_aleatoria_larga_de_al_menos_32_caracteres
