# =============================================================================
# CONFIGURACIÓN DEL SISTEMA DE MONITOREO DE CALIDAD DEL AIRE - XALAPA
# =============================================================================
# Copia este archivo como .env y ajusta los valores según tu entorno

# =============================================================================
# BASE DE DATOS PostgreSQL
# =============================================================================
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/air_quality_xalapa

# =============================================================================
# APIs EXTERNAS
# =============================================================================
# TomTom Traffic API - https://developer.tomtom.com/
TOMTOM_API_KEY=tu_tomtom_api_key_aqui

# AQICN (opcional) - https://aqicn.org/data-platform/token/
AQICN_API_KEY=tu_aqicn_api_key_aqui

# Google Maps (opcional)
GOOGLE_MAPS_API_KEY=tu_google_maps_api_key_aqui

# =============================================================================
# CONFIGURACIÓN DEL SERVIDOR
# =============================================================================
HOST=localhost
PORT=8000
DEBUG=True
SECRET_KEY=genera_una_clave_secreta_segura_para_produccion

# =============================================================================
# CONFIGURACIÓN DE CORS (Importante para seguridad)
# =============================================================================
# En desarrollo: permite todos los orígenes
CORS_ORIGINS=*

# En producción: especifica los dominios permitidos separados por coma
# Ejemplo: CORS_ORIGINS=https://tu-frontend.vercel.app,https://tu-dominio.com

# =============================================================================
# ENTORNO
# =============================================================================
# Valores: development, production
ENVIRONMENT=development

# =============================================================================
# CONFIGURACIÓN DE EMAIL PARA NOTIFICACIONES
# =============================================================================
# Para Gmail: 
# 1. Usa tu correo de Gmail
# 2. Genera una "Contraseña de aplicación" en tu cuenta de Google
#    (Settings > Security > 2-Step Verification > App passwords)
# 3. NO uses tu contraseña normal de Gmail

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_contraseña_de_aplicacion
EMAIL_FROM=Sistema de Calidad del Aire <tu_correo@gmail.com>
EMAIL_USE_TLS=True
